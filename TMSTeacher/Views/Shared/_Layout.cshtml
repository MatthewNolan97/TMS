<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TMS Teacher Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Teacher.css" />
</head>
<body>
    <header class="header">
        <h1>Toy Management System - Teacher Portal</h1>

        @* <nav>
            <ul class="header-nav-list">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Student" asp-action="Index">Reports</a>
                    </li>
                }
                <li class="nav-item">
                    <div class="theme-toggle" onclick="toggleTheme()">
                        <span class="theme-icon sun-icon">☀️</span>
                        <span class="theme-icon moon-icon">🌙</span>
                    </div>
                </li>
            </ul>
        </nav>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="header-actions">
                <partial name="_Notifications" />
                <a class="btn btn-danger" href="/MicrosoftIdentity/Account/SignOut">Sign Out</a>
            </div>
        } *@
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#teacherNavbar"
                        aria-controls="teacherNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="teacherNavbar">
                    <ul class="navbar-nav ms-lg-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Student" asp-action="Index">Reports</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Backup" asp-action="Index">Backup and Restore Data</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="btn btn-danger" href="/MicrosoftIdentity/Account/SignOut">Sign Out</a>
                        </li>
                        <li class="nav-item">
                            <div class="theme-toggle" onclick="toggleTheme()">
                                <span class="theme-icon sun-icon">☀️</span>
                                <span class="theme-icon moon-icon">🌙</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-top">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <span class="footer-logo-line"></span>
                        <span class="footer-logo-line"></span>
                        <span class="footer-logo-line"></span>
                        <h2>TMS</h2>
                    </div>
                    <p class="footer-description">
                        The Toy Management System helps organize and track educational
                        toys used in the Early Childhood Education program.
                    </p>
                </div>
            </div>

            <hr class="footer-divider">

            <div class="footer-bottom">
                <p class="footer-copyright">© 2026 All Rights Reserved</p>
                @* <nav class="footer-links">
                    <a href="#" class="footer-link">Privacy Policy</a>
                    <a href="#" class="footer-link">Terms of Use</a>
                    <a href="#" class="footer-link">Legal</a>
                    <a href="#" class="footer-link">Site Map</a>
                </nav> *@
                <button class="scroll-to-top" id="scrollToTop" aria-label="Scroll to top">
                    <i class="bi bi-chevron-up"></i>
                </button>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        var oidClaim = User.FindFirst("oid") ?? User.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier");
        var nameClaim = User.FindFirst("name") ?? User.FindFirst(System.Security.Claims.ClaimTypes.Name);
        var userType = "Student";
        if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            userType = "Teacher";
        }
        else if (User.IsInRole("Student"))
        {
            userType = "Student";
        }
        
        if (oidClaim != null)
        {
            <script>
                console.log("==========================================");
                console.log("User Name: @(nameClaim?.Value ?? "N/A")");
                console.log("OID (Object Identifier): @oidClaim.Value");
                console.log("User Type: @userType");
                console.log("==========================================");
            </script>
        }
    }
    <script>
        function toggleTheme() {
            document.body.classList.toggle('dark-mode');
            const isDarkMode = document.body.classList.contains('dark-mode');
            localStorage.setItem('theme', isDarkMode ? 'dark' : 'light');
        }

        // Load saved theme preference on page load
        document.addEventListener('DOMContentLoaded', function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.body.classList.add('dark-mode');
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
